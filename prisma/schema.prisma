generator client {
  provider = "prisma-client-js"
}

datasource db{
  provider="postgresql"
  url=env("DATABASE_URL")
  directUrl=env("DIRECT_URL")
}

model User {
  id        String   @id
  email     String   @unique
  password  String?  // <--- Add the '?' to make it optional
  FirstName String? 
  LastName  String?
  role          Role  @default(USER)
  // team          Team?     @relation(fields: [teamID], references: [id], onDelete: setNull)
  orders        Order[]
  cartItems     CartItem[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Team {
  id            String    @id 
  email         String    @unique
  name          String?
  role          Role  @default(USER)
  code          String  @unique
  // members       User[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role{
  ADMIN
  MANAGER
  USER
  GUEST
}
model Product {
  id          String     @id 
  name        String
  price       Float
  category    String     // Upper or Sole
  image       String
  stock       Int        @default(100)
  cartItems   CartItem[]
}

model CartItem {
  id        String   @id 
  userId    String
  productId String
  size      String
  qty       Int      @default(1)
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model Order {
  id          String   @id
  userId      String
  totalAmount Float
  status      String   @default("PENDING") // PENDING, PAID, SHIPPED
  stripeId    String?  @unique
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}



